# BoardPilot FlyingRC private deployment profile.
# Copy this file to .env for an internal FlyingRC deployment, then replace secrets.

BOARDPILOT_ENV=private
BOARDPILOT_API_HOST=0.0.0.0
BOARDPILOT_API_PORT=8000
BOARDPILOT_API_HOST_PORT=8000
BOARDPILOT_WEB_HOST_PORT=3001

BOARDPILOT_STORAGE_ROOT=/app/storage
BOARDPILOT_AUDIT_LOG_PATH=/app/storage/audit/audit.jsonl
BOARDPILOT_DATABASE_URL=postgresql+psycopg://boardpilot:boardpilot@db:5432/boardpilot
BOARDPILOT_REDIS_URL=redis://redis:6379/0

# Replace before use. Keep this private inside the FlyingRC network.
BOARDPILOT_API_KEY=replace-with-a-long-random-secret
NEXT_PUBLIC_BOARDPILOT_API_KEY=replace-with-a-long-random-secret

BOARDPILOT_SESSION_TTL_SECONDS=86400
BOARDPILOT_SESSION_MAX_TTL_SECONDS=604800
BOARDPILOT_USERS_JSON={"lyhenry":"admin","support":"support","maintainer":"maintainer","reviewer":"reviewer","evaluator":"evaluator"}

BOARDPILOT_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BOARDPILOT_SESSION_TOKEN=

# Keep fake providers for the first FlyingRC validation pass.
BOARDPILOT_LLM_PROVIDER=fake
BOARDPILOT_EMBEDDING_PROVIDER=fake
BOARDPILOT_RERANKER_PROVIDER=fake
BOARDPILOT_OCR_PROVIDER=fake

# Set only after the privacy boundary is approved.
OPENAI_API_KEY=
COHERE_API_KEY=
