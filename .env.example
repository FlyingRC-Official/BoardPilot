# BoardPilot private deployment configuration.
# Copy to .env before running `docker compose up --build`.

# Runtime mode label. Keep `local` for development; use `private` for a deployed stack.
BOARDPILOT_ENV=local

# API bind address inside the container.
BOARDPILOT_API_HOST=0.0.0.0
BOARDPILOT_API_PORT=8000

# Local filesystem storage for uploads, parsed artifacts, and optional audit JSONL.
BOARDPILOT_STORAGE_ROOT=/app/storage
BOARDPILOT_AUDIT_LOG_PATH=/app/storage/audit/audit.jsonl

# Required for private deployments. Leave empty only for local development.
# The same value must be set in NEXT_PUBLIC_BOARDPILOT_API_KEY for the bundled web workbench.
BOARDPILOT_API_KEY=

# Comma-separated browser origins allowed to call the API.
BOARDPILOT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Docker Compose service URLs.
BOARDPILOT_DATABASE_URL=postgresql+psycopg://boardpilot:boardpilot@db:5432/boardpilot
BOARDPILOT_REDIS_URL=redis://redis:6379/0

# Provider defaults. Non-fake provider configs are recorded but require adapter implementation.
BOARDPILOT_LLM_PROVIDER=fake
BOARDPILOT_EMBEDDING_PROVIDER=fake
BOARDPILOT_RERANKER_PROVIDER=fake
BOARDPILOT_OCR_PROVIDER=fake

# Web workbench runtime configuration.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BOARDPILOT_API_KEY=
